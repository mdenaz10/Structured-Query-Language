BEGIN TRAN

CREATE TABLE #TmpAgr (
	AGRMNT_NO varchar(50)
)

INSERT INTO #TmpAgr
VALUES
	('26143101399')

SELECT
	'BEFORE' AS DATA_STATUS,
	a.AGRMNT_NO,
	c.CUST_NAME,
	isp.POLICY_NO,
	iac.AGRMNT_ASSET_ID,
	ib.INSCO_BRANCH_NAME,
	iac.INSCO_BRANCH_ID AS IACBRANCH,
	iai.INSCO_BRANCH_ID AS IAIBRANCH
FROM AGRMNT a WITH (NOLOCK)
LEFT JOIN CUST c WITH (NOLOCK) ON a.CUST_ID = c.CUST_ID
INNER JOIN AGRMNT_ASSET aa WITH (NOLOCK) ON a.AGRMNT_ID = aa.AGRMNT_ID
INNER JOIN INS_ASSET_CUST iac WITH (NOLOCK) ON aa.AGRMNT_ASSET_ID = iac.AGRMNT_ASSET_ID
INNER JOIN INS_ASSET_INSCO iai WITH(NOLOCK) ON aa.AGRMNT_ASSET_ID = iai.AGRMNT_ASSET_ID
INNER JOIN INSCO_BRANCH ib WITH (NOLOCK) ON iai.INSCO_BRANCH_ID = ib.INSCO_BRANCH_ID
INNER JOIN INS_SPPA_POLICY ISP WITH (NOLOCK) ON IAC.INS_SPPA_POLICY_ID = ISP.INS_SPPA_POLICY_ID
WHERE a.AGRMNT_NO IN (
	SELECT AGRMNT_NO
	FROM #TmpAgr
)
ORDER BY ib.INSCO_BRANCH_NAME ASC, c.CUST_NAME ASC

SELECT @@ROWCOUNT AS ROW_BEFORE

UPDATE INS_ASSET_CUST 
SET
	INSCO_BRANCH_ID = 6,
	DTM_UPD = GETDATE(),
	USR_UPD = 'William'
WHERE AGRMNT_ASSET_ID in (
	SELECT
		DISTINCT iac.AGRMNT_ASSET_ID
	FROM AGRMNT a WITH (NOLOCK)
	INNER JOIN AGRMNT_ASSET aa WITH (NOLOCK) ON a.AGRMNT_ID = aa.AGRMNT_ID
	INNER JOIN INS_ASSET_CUST iac WITH (NOLOCK) ON aa.AGRMNT_ASSET_ID = iac.AGRMNT_ASSET_ID
    INNER JOIN INS_ASSET_INSCO iai WITH(NOLOCK) ON aa.AGRMNT_ASSET_ID = iai.AGRMNT_ASSET_ID
	INNER JOIN INSCO_BRANCH ib WITH (NOLOCK) ON iac.INSCO_BRANCH_ID = ib.INSCO_BRANCH_ID
	WHERE a.AGRMNT_NO IN (
		SELECT AGRMNT_NO
		FROM #TmpAgr
	)
)

SELECT @@ROWCOUNT AS ROW_UPDATE_IAC

UPDATE INS_ASSET_INSCO
SET
	INSCO_BRANCH_ID = 6,
	DTM_UPD = GETDATE(),
	USR_UPD = 'William'
WHERE AGRMNT_ASSET_ID in (
	SELECT
		DISTINCT iac.AGRMNT_ASSET_ID
	FROM AGRMNT a WITH (NOLOCK)
	INNER JOIN AGRMNT_ASSET aa WITH (NOLOCK) ON a.AGRMNT_ID = aa.AGRMNT_ID
	INNER JOIN INS_ASSET_CUST iac WITH (NOLOCK) ON aa.AGRMNT_ASSET_ID = iac.AGRMNT_ASSET_ID
    INNER JOIN INS_ASSET_INSCO iai WITH(NOLOCK) ON aa.AGRMNT_ASSET_ID = iai.AGRMNT_ASSET_ID
	INNER JOIN INSCO_BRANCH ib WITH (NOLOCK) ON iac.INSCO_BRANCH_ID = ib.INSCO_BRANCH_ID
	WHERE a.AGRMNT_NO IN (
		SELECT AGRMNT_NO
		FROM #TmpAgr
	)
)

SELECT @@ROWCOUNT AS ROW_UPDATE_IAI

UPDATE INS_SPPA_POLICY
SET
	POLICY_NO = '4202212201078-002428',
	DTM_UPD = GETDATE(),
	USR_UPD = 'Wiliam'
WHERE INS_SPPA_POLICY_ID in (
	select INS_SPPA_POLICY_ID
	from ins_asset_cust iac
	join agrmnt_asset aa on aa.AGRMNT_ASSET_ID = iac.AGRMNT_ASSET_ID
	join agrmnt a on a.agrmnt_id = aa.agrmnt_id
		WHERE a.AGRMNT_NO IN (
			SELECT AGRMNT_NO
			FROM #TmpAgr
		)
	)

SELECT @@ROWCOUNT AS ROW_UPDATE_ISP

SELECT
	'AFTER' AS DATA_STATUS,
	a.AGRMNT_NO,
	c.CUST_NAME,
	isp.policy_no,
	iac.AGRMNT_ASSET_ID,
	ib.INSCO_BRANCH_NAME,
	iac.INSCO_BRANCH_ID AS IACBRANCH,
	iai.INSCO_BRANCH_ID AS IAIBRANCH
FROM AGRMNT a WITH (NOLOCK)
LEFT JOIN CUST c WITH (NOLOCK) ON a.CUST_ID = c.CUST_ID
INNER JOIN AGRMNT_ASSET aa WITH (NOLOCK) ON a.AGRMNT_ID = aa.AGRMNT_ID
INNER JOIN INS_ASSET_CUST iac WITH (NOLOCK) ON aa.AGRMNT_ASSET_ID = iac.AGRMNT_ASSET_ID
INNER JOIN INS_ASSET_INSCO iai WITH(NOLOCK) ON aa.AGRMNT_ASSET_ID = iai.AGRMNT_ASSET_ID
INNER JOIN INSCO_BRANCH ib WITH (NOLOCK) ON iai.INSCO_BRANCH_ID = ib.INSCO_BRANCH_ID
INNER JOIN INS_SPPA_POLICY ISP WITH (NOLOCK) ON IAC.INS_SPPA_POLICY_ID = ISP.INS_SPPA_POLICY_ID
WHERE a.AGRMNT_NO IN (
	SELECT AGRMNT_NO
	FROM #TmpAgr
)
ORDER BY ib.INSCO_BRANCH_NAME ASC, c.CUST_NAME ASC

SELECT @@ROWCOUNT AS ROW_AFTER

DROP TABLE #TmpAgr

ROLLBACK TRAN

COMMIT TRAN
